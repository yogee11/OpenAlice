{
  "name": "open-alice",
  "version": "0.21.0-beta.5",
  "description": "File-based trading agent engine",
  "type": "module",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "tsx scripts/guardian/dev.ts",
    "prebuild": "tsx scripts/build-migration-index.ts",
    "build": "turbo run build && tsup src/main.ts --format esm --dts",
    "build:migration-index": "tsx scripts/build-migration-index.ts",
    "start": "node dist/main.js",
    "electron:tsc": "tsc -p electron/tsconfig.json",
    "electron:build": "pnpm build && pnpm electron:tsc",
    "electron:dev": "pnpm electron:build && electron dist/electron/main.js",
    "electron:pack": "pnpm electron:build && electron-builder --dir",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:bbProvider": "vitest run --config vitest.bbProvider.config.ts",
    "postinstall": "node scripts/fix-pty-perms.mjs"
  },
  "keywords": [
    "trading",
    "ai-agent",
    "crypto",
    "securities",
    "file-driven"
  ],
  "author": "OpenAlice Contributors",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TraderAlice/OpenAlice.git"
  },
  "homepage": "https://traderalice.com",
  "packageManager": "pnpm@10.29.2",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.44",
    "@ai-sdk/google": "^3.0.30",
    "@ai-sdk/openai": "^3.0.30",
    "@alpacahq/alpaca-trade-api": "^3.1.3",
    "@anthropic-ai/claude-agent-sdk": "^0.2.72",
    "@anthropic-ai/sdk": "^0.96.0",
    "@grammyjs/auto-retry": "^2.0.2",
    "@hono/node-server": "^2.0.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@sinclair/typebox": "0.34.48",
    "@traderalice/ibkr": "workspace:*",
    "@traderalice/opentypebb": "workspace:*",
    "@traderalice/uta-protocol": "workspace:*",
    "ai": "^6.0.86",
    "ajv": "^8.18.0",
    "ccxt": "^4.5.38",
    "decimal.js": "^10.6.0",
    "grammy": "^1.40.0",
    "hono": "^4.12.14",
    "longbridge": "^4.0.5",
    "node-pty": "^1.1.0",
    "openai": "^6.33.0",
    "pino": "^10.3.1",
    "viem": "^2.48.7",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "build": {
    "appId": "com.traderalice.openalice",
    "productName": "OpenAlice",
    "directories": {
      "output": "dist/electron-app"
    },
    "files": [
      "dist/main.js",
      "dist/electron/**",
      "ui/dist/**",
      "default/**",
      "package.json"
    ],
    "mac": {
      "target": "dir"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "node-pty",
      "electron"
    ],
    "overrides": {
      "@alpacahq/alpaca-trade-api>axios": "^0.31.1",
      "@alpacahq/alpaca-trade-api>eslint": "-",
      "lodash": "^4.18.0",
      "path-to-regexp": "^8.4.0",
      "follow-redirects": "^1.16.0",
      "express-rate-limit": "^8.2.2",
      "picomatch": "^4.0.4",
      "rollup": "^4.59.0",
      "vitest>vite": "^7.3.2",
      "@vitest/mocker>vite": "^7.3.2"
    }
  },
  "devDependencies": {
    "@ai-sdk/provider": "^3.0.8",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.5",
    "electron": "^38.0.0",
    "electron-builder": "^25.1.8",
    "jsdom": "^29.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "turbo": "^2.9.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
