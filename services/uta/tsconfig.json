{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "outDir": "dist",
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "paths": {
      "@/*": ["../../src/*"]
    },
    "customConditions": ["openalice-source"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
